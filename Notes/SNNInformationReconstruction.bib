	keywords = {Backpropagation, Backpropagation through time, Inference algorithms, Local Learning Rule, Memory management, Neural activity, Neurons, On-device Learning, Spiking neural networks, Spiking Neural Networks, Synchronization, Training, Voltage control},
	pages = {1--9},
